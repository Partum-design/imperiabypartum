# Public client keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side secret key (do NOT commit real values).
# IMPORTANT: this key must NOT live in source code.
# Add it manually in Vercel -> Project Settings -> Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
